{
    "dockerFile": "./Dockerfile",
    "containerUser": "admin",
    "workspaceFolder": "/app",
    "mounts": [
        "source=${localWorkspaceFolder}/,target=/app,type=bind"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go"
            ],
            "settings": {
                "gopls": {
                    "ui.semanticTokens": true
                }
            }
        }
    }
}
